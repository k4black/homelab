  timemachine:
    image: mbentley/timemachine:smb
    container_name: timemachine
    hostname: timemachine
    environment:
      TZ: {{ timezone }}
      TM_USERNAME: timemachine
      TM_GROUPNAME: timemachine
      PASSWORD: timemachine
      TM_UID: 1000
      TM_GID: 1000
      CUSTOM_SMB_CONF: false
      CUSTOM_USER: false
      EXTERNAL_CONF: ""
      HIDE_SHARES: "no"
      MIMIC_MODEL: "TimeCapsule8,119"
      SMB_PORT: 445
      SET_PERMISSIONS: "false"
      SMB_INHERIT_PERMISSIONS: "no"
      SMB_NFS_ACES: "yes"
      SMB_METADATA: "stream"
      SMB_VFS_OBJECTS: "acl_xattr fruit streams_xattr"
      VOLUME_SIZE_LIMIT: "0"  # unlimited
      DEBUG_LEVEL: 3
    volumes:
        - /mnt/timemachine:/opt/timemachine
        - timemachine-var-lib-samba:/var/lib/samba
        - timemachine-var-cache-samba:/var/cache/samba
        - timemachine-run-samba:/run/samba
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "137:137/udp"
      - "138:138/udp"
      - "139:139"
      - "445:445"
{#    network_mode: host#}
    labels:
      - homepage.group=Storage
      - homepage.name=Time Machine
      - homepage.icon=apple
    restart: unless-stopped

  ### Downloads ###
  transmission:
    image: linuxserver/transmission:4.1.1
    container_name: transmission
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
    ports:
      - "9091:9091"
      - "51413:51413"
      - "51413:51413/udp"
    volumes:
      - {{ containers_setup_configs_dir }}/transmission-config:/config
      - /mnt/backups/downloads:/downloads
    labels:
      - homepage.group=Storage
      - homepage.name=Transmission
      - homepage.icon=transmission
      - homepage.href=http://{{ local_ipv4 }}:9091
      - homepage.statusStyle=basic
      - homepage.ping=http://transmission:9091
      - homepage.widget.type=transmission
      - homepage.widget.url=http://transmission:9091
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9091"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  ### Metrics ###
  glances:
    image: nicolargo/glances:4.3.1-full
    container_name: glances
    pid: host
    environment:
      TZ: {{ timezone }}
      GLANCES_OPT: "-w"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /:/rootfs:ro
      - /etc/os-release:/etc/os-release:ro
    ports:
      - "61208:61208"
    labels:
      - homepage.group=Monitoring
      - homepage.name=Glances
      - homepage.icon=glances
      - homepage.href=http://{{ local_ipv4 }}:61208
      - homepage.statusStyle=basic
      - homepage.ping=http://glances:61208
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:61208/api/4/status"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  netdata:
    image: netdata/netdata:v2.10
    container_name: netdata
    hostname: {{ device_name }}
    pid: host
    network_mode: host
    cap_add:
      - SYS_PTRACE
      - SYS_ADMIN
    security_opt:
      - apparmor:unconfined
    environment:
      - DISABLE_TELEMETRY=1
    volumes:
      - {{ containers_setup_configs_dir }}/netdata-config/netdata.conf:/etc/netdata/netdata.conf:ro
      - {{ containers_setup_configs_dir }}/netdata-config/stream.conf:/etc/netdata/stream.conf:ro
      - {{ containers_setup_configs_dir }}/netdata-config/go.d/pihole.conf:/etc/netdata/go.d/pihole.conf:ro
      - netdata-lib:/var/lib/netdata
      - netdata-cache:/var/cache/netdata
      - /:/host/root:ro,rslave
      - /etc/passwd:/host/etc/passwd:ro
      - /etc/group:/host/etc/group:ro
      - /etc/localtime:/etc/localtime:ro
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /etc/os-release:/host/etc/os-release:ro
      - /var/log:/host/var/log:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    labels:
      - homepage.group=Monitoring
      - homepage.name=Netdata
      - homepage.icon=netdata
      - homepage.href=http://{{ local_ipv4 }}:19999
      - homepage.statusStyle=basic
      - homepage.ping=http://{{ local_ipv4 }}:19999
      - homepage.widget.type=netdata
      - homepage.widget.url=http://{{ local_ipv4 }}:19999
    restart: unless-stopped
