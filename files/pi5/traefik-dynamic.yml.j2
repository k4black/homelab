http:
  middlewares:
    # Allow only trusted networks. Applied as the default middleware on the `web`
    # entrypoint (see traefik-config.yml.j2), so any router without an explicit
    # opt-out inherits the restriction.
    internal-only:
      ipAllowList:
        sourceRange:
          - 127.0.0.0/8                          # loopback
          - 192.168.1.0/24                       # home LAN
          - {{ vpn_network_subnet }}             # WireGuard clients
          - 100.64.0.0/10                        # Tailscale CGNAT
          - {{ pi5_docker_network_subnet }}      # pi5 docker bridge
          - 172.16.0.0/12                        # default docker bridges
