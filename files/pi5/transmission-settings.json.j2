{# {{ ansible_managed }} — canonical Transmission settings.json for the TRaSH /data layout. #}
{# Paths: download-dir is the default; Radarr/Sonarr override per-torrent to /data/torrents/{movies,tv}. #}
{# incomplete-dir kept on the same fs so move-on-complete is atomic rename. #}
{# Notes embedded as Jinja {# #} comments — stripped at template time so the rendered JSON is clean. #}
{# LSIO clobbers some keys (umask, peer-port, rpc-*) from env vars on every start — see compose. #}
{
  "download-dir": "/data/torrents",
  "incomplete-dir": "/data/torrents/.incomplete",
  "incomplete-dir-enabled": true,
  "rename-partial-files": true,
  "preallocation": 1,
  "start-added-torrents": true,
  "trash-original-torrent-files": false,

  "script-torrent-added-enabled": false,
  "script-torrent-done-enabled": false,
  "script-torrent-done-seeding-enabled": false,

  "cache-size-mb": 64,
  "peer-limit-global": 200,
  "peer-limit-per-torrent": 50,
  "download-queue-enabled": true,
  "download-queue-size": 5,
  "seed-queue-enabled": false,
  "queue-stalled-enabled": true,
  "queue-stalled-minutes": 30,

  "ratio-limit": 2.0,
  "ratio-limit-enabled": false,
  "idle-seeding-limit": 30,
  "idle-seeding-limit-enabled": false,

  "encryption": 1,
  "dht-enabled": true,
  "pex-enabled": true,
  "lpd-enabled": false,
  "utp-enabled": true,
  "tcp-enabled": true,
  "port-forwarding-enabled": false,
  "peer-port": 51413,
  "peer-port-random-on-start": false,

  "rpc-enabled": true,
  "rpc-port": 9091,
  "rpc-url": "/transmission/",
  "rpc-bind-address": "0.0.0.0",
  "rpc-authentication-required": false,
  "rpc-whitelist-enabled": false,
  "rpc-host-whitelist-enabled": false,

  "umask": 2,

  "blocklist-enabled": false,
  {# Speed limits applied by default — a residential uplink saturated by Transmission
     kills latency for everything else on the LAN. Override via vars/pi5.yml if needed. #}
  "speed-limit-down": {{ transmission_speed_limit_down_kbps | default(20000) }},
  "speed-limit-down-enabled": {{ (transmission_speed_limit_down_enabled | default(true)) | string | lower }},
  "speed-limit-up": {{ transmission_speed_limit_up_kbps | default(1000) }},
  "speed-limit-up-enabled": {{ (transmission_speed_limit_up_enabled | default(true)) | string | lower }}
}
