# {{ ansible_managed }}

[global]
    hostname = {{ device_name }}
    # Collect every 2s instead of 1s — halves baseline CPU on a Pi 5;
    # homepage/glances widgets refresh much slower so loses no useful resolution.
    update every = 2

# apps.plugin walks the full process tree every tick — by far the heaviest collector.
[plugin:apps]
    update every = 5

# Per-cgroup metrics for every container; we don't need 1s resolution either.
[plugin:cgroups]
    update every = 5

[db]
    mode = dbengine
    storage tiers = 3
    dbengine page cache size MB = 64
    dbengine tier 0 retention time = 14d
    dbengine tier 1 update every iterations = 60
    dbengine tier 1 retention time = 3mo
    dbengine tier 2 update every iterations = 60
    dbengine tier 2 retention time = 2y
    replication threads = 2
    cleanup obsolete charts after = 3d
    cleanup orphan hosts after = 30d

[web]
    bind to = *

[ml]
    enabled = no
