  timemachine:
    image: mbentley/timemachine:smb
    container_name: timemachine
    hostname: timemachine
    environment:
      TZ: {{ timezone }}
      TM_USERNAME: timemachine
      TM_GROUPNAME: timemachine
      PASSWORD: timemachine
      TM_UID: 1000
      TM_GID: 1000
      CUSTOM_SMB_CONF: false
      CUSTOM_USER: false
      EXTERNAL_CONF: ""
      HIDE_SHARES: "no"
      MIMIC_MODEL: "TimeCapsule8,119"
      SMB_PORT: 445
      SET_PERMISSIONS: "false"
      SMB_INHERIT_PERMISSIONS: "no"
      SMB_NFS_ACES: "yes"
      SMB_METADATA: "stream"
      SMB_VFS_OBJECTS: "acl_xattr fruit streams_xattr"
      VOLUME_SIZE_LIMIT: "0"  # unlimited
      DEBUG_LEVEL: 3
    volumes:
        - /mnt/timemachine:/opt/timemachine
        - timemachine-var-lib-samba:/var/lib/samba
        - timemachine-var-cache-samba:/var/cache/samba
        - timemachine-run-samba:/run/samba
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "137:137/udp"
      - "138:138/udp"
      - "139:139"
      - "445:445"
{#    network_mode: host#}
    labels:
      - homepage.group=Storage
      - homepage.name=Time Machine
      - homepage.icon=apple
    restart: unless-stopped

  ### Media ###
  # Direct-play media server for LAN clients (iOS/Apple TV/Mac). Mounts the
  # media subset of the storage pool read-only so the UI can't delete source files.
  # Library is split into /media/movies (Radarr) and /media/tv (Sonarr). No HW
  # transcoding configured — Pi 5's VideoCore VII V4L2 path is still maturing in
  # 2025-2026, and modern clients direct-play H.264/HEVC fine. To enable HW
  # transcode later: pass `--device /dev/dri` and configure Jellyfin > Playback >
  # VAAPI in the admin UI.
  jellyfin:
    image: jellyfin/jellyfin:10.11.8
    container_name: jellyfin
    # Jellyfin reads the server name from the container hostname on first start —
    # without this it shows a container-hash string in the UI.
    hostname: {{ device_name }}
    user: "1000:1000"
    environment:
      TZ: {{ timezone }}
      # JELLYFIN_PublishedServerUrl intentionally unset — single value would only
      # match one of LAN-IP / Tailscale / pi5.local; leave it unset for clients
      # to use the request's own origin.
    ports:
      - "8096:8096"
      - "7359:7359/udp"   # LAN auto-discovery (Swiftfin/Findroid find the server)
    volumes:
      - {{ containers_setup_data_dir }}/jellyfin/config:/config
      - {{ containers_setup_data_dir }}/jellyfin/cache:/cache
      - /mnt/storage/media:/media:ro
    labels:
      - homepage.group=Media
      - homepage.name=Jellyfin
      - homepage.icon=jellyfin
      - homepage.href=http://homepage_host:8096
      - homepage.statusStyle=basic
      - homepage.ping=http://jellyfin:8096
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:8096/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # Indexer aggregator. Replaces Jackett; Radarr/Sonarr pull indexers from here.
  # No auth by default — relies on LAN/VPN gating. To set a password later,
  # visit Settings > General in the UI.
  prowlarr:
    image: linuxserver/prowlarr:2.3.5
    container_name: prowlarr
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
    ports:
      - "9696:9696"
    volumes:
      - {{ containers_setup_data_dir }}/prowlarr/config:/config
    labels:
      - homepage.group=Media
      - homepage.name=Prowlarr
      - homepage.icon=prowlarr
      - homepage.href=http://homepage_host:9696
      - homepage.statusStyle=basic
      - homepage.ping=http://prowlarr:9696
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:9696/ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # Movie automation. TRaSH-canonical single /data mount — both /data/torrents
  # (download dir, populated by Transmission) and /data/media (library) live
  # under one bind mount so hardlinks (atomic, no copy) stay within one mounted
  # filesystem from the container's perspective. Path translation against
  # Transmission's /downloads view happens via Radarr's Remote Path Mapping
  # configured in tasks/configure_arr_stack.yml.
  radarr:
    image: linuxserver/radarr:6.1.1
    container_name: radarr
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
    ports:
      - "7878:7878"
    volumes:
      - {{ containers_setup_data_dir }}/radarr/config:/config
      - /mnt/storage:/data
    labels:
      - homepage.group=Media
      - homepage.name=Radarr
      - homepage.icon=radarr
      - homepage.href=http://homepage_host:7878
      - homepage.statusStyle=basic
      - homepage.ping=http://radarr:7878
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:7878/ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # CloudFlare-challenge solver for Prowlarr. Many public trackers (1337x,
  # KickAssTorrents, sometimes LimeTorrents/EZTV) sit behind CloudFlare —
  # they fail Prowlarr's connectivity test otherwise. Wired into Prowlarr's
  # "Indexer Proxy" with a tag; indexers tagged the same way route their
  # requests through this container. Note: FS runs a headless Chromium
  # (200-400 MB RAM) — pay the cost only when CF-protected indexers are wanted.
  flaresolverr:
    image: ghcr.io/flaresolverr/flaresolverr:v3.3.21
    container_name: flaresolverr
    environment:
      LOG_LEVEL: info
      TZ: {{ timezone }}
    ports:
      - "8191:8191"
    labels:
      - homepage.group=Media
      - homepage.name=FlareSolverr
      - homepage.icon=flaresolverr
      - homepage.href=http://homepage_host:8191
      - homepage.statusStyle=basic
      - homepage.ping=http://flaresolverr:8191
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://localhost:8191/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # TV automation. Same canonical /data mount as Radarr — see comment above.
  sonarr:
    image: linuxserver/sonarr:4.0.17
    container_name: sonarr
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
    ports:
      - "8989:8989"
    volumes:
      - {{ containers_setup_data_dir }}/sonarr/config:/config
      - /mnt/storage:/data
    labels:
      - homepage.group=Media
      - homepage.name=Sonarr
      - homepage.icon=sonarr
      - homepage.href=http://homepage_host:8989
      - homepage.statusStyle=basic
      - homepage.ping=http://sonarr:8989
    healthcheck:
      test: ["CMD", "curl", "-fsS", "http://localhost:8989/ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  ### AI ###
  hermes:
    image: nousresearch/hermes-agent:v2026.6.19
    container_name: hermes
    environment:
      TZ: {{ timezone }}
      # Remap the image's internal uid/gid 10000 -> 1000 so files written to the
      # /opt/data bind mount stay owned by {{ username }} (1000) on the host.
      HERMES_UID: "1000"
      HERMES_GID: "1000"
      # Run the web dashboard inside this container; the port is published on the
      # host (below) and reached directly by host:port like the other services
      # here (no Traefik route). --insecure: no-auth, acceptable behind the
      # VPN/LAN gating. Bind to all interfaces so the published port works.
      HERMES_DASHBOARD: "true"
      HERMES_DASHBOARD_HOST: 0.0.0.0
      HERMES_DASHBOARD_PORT: "9119"
      HERMES_DASHBOARD_INSECURE: "true"
      # LLM provider (model/provider/base_url are in config.yaml).
      OPENROUTER_API_KEY: {{ hermes_openrouter_api_key }}
      # Telegram gateway — token present => the gateway enables the bot. The
      # allowlist restricts who may talk to it (numeric Telegram user IDs).
      TELEGRAM_BOT_TOKEN: {{ hermes_telegram_bot_token }}
      TELEGRAM_ALLOWED_USERS: "{{ hermes_telegram_allowed_users }}"
      # GitHub PAT (fine-grained, k4black/dotfiles, Contents R/W) for the
      # github-* skills + git credential helper in ~/.gitconfig (lets Hermes
      # pull/commit/push the dotfiles skills repo cloned at /opt/data/skills-repo).
      GITHUB_TOKEN: {{ hermes_github_pat }}
      # The anki-connect skill talks to the sibling `anki` container over the
      # bridge. NOTE: the skill currently hardcodes http://localhost:8765 — it
      # must read this env (a one-line edit Hermes can make + push to dotfiles).
      ANKI_CONNECT_URL: http://anki:8765
    ports:
      - "9119:9119"
    volumes:
      # HERMES_HOME — holds config.yaml, session history, vector memory, learned
      # skills, and logs. config.yaml is rendered here before first start.
      - {{ containers_setup_data_dir }}/hermes:/opt/data
    command: ["gateway", "run"]
    labels:
      - homepage.group=Services
      - homepage.name=Hermes
      - homepage.icon=mdi-robot-happy
      - homepage.href=http://homepage_host:9119
      - homepage.statusStyle=basic
      - homepage.ping=http://hermes:9119
    healthcheck:
      # /api/status is the dashboard's public status endpoint (no auth).
      test: ["CMD", "curl", "-fsS", "http://localhost:9119/api/status"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # Headless Anki + AnkiConnect (no GUI). Built locally from the upstream
  # ThisIsntTheWay/headless-anki clone with a patched, arch-aware Dockerfile
  # (files/pi5/anki.Dockerfile -> Dockerfile.pi5 in the clone): official
  # anki-26.05-linux-aarch64 on debian:13-slim (glibc 2.41). The published
  # kaiimehra arm64 image can't run here (built on glibc 2.35 < Anki's 2.36).
  # Exposes AnkiConnect on :8765 for the agent's anki-connect skill (Hermes
  # reaches it at http://anki:8765 — see ANKI_CONNECT_URL on the hermes service).
  # Named volume seeds /data from the image's baked profile; QT_QPA_PLATFORM=
  # offscreen keeps it headless (set "vnc" + publish 5900 for a one-time GUI
  # AnkiWeb login).
  anki:
    build:
      context: {{ anki_build_dir }}
      dockerfile: Dockerfile.pi5
    image: headless-anki-pi5:local
    container_name: anki
    environment:
      TZ: {{ timezone }}
      # Set AnkiConnect's webCorsOriginList to ["*"] so cross-origin callers work.
      ANKICONNECT_WILDCARD_ORIGIN: "1"
      # Headless — no VNC/X server needed for API-only use.
      QT_QPA_PLATFORM: offscreen
    ports:
      - "8765:8765"
    volumes:
      - anki-data:/data
      - anki-export:/export
    labels:
      - homepage.group=Services
      - homepage.name=Anki
      - homepage.icon=anki
      - homepage.href=http://homepage_host:8765
      - homepage.statusStyle=basic
      - homepage.ping=http://anki:8765
    healthcheck:
      # AnkiConnect is POST-only — a bare GET returns non-2xx. Probe the real API.
      test: ["CMD-SHELL", "curl -fsS http://localhost:8765 -X POST -d '{\"action\":\"version\",\"version\":6}' | grep -q result"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  ### Files ###
  # Auth is disabled (`--noauth`) — relies on VPN/Tailscale/LAN restriction for
  # access control. `--noauth` only takes effect during quickSetup() on an empty
  # /database; to flip it later, wipe /database/filebrowser.db on the host and
  # recreate the container.
  filebrowser:
    image: filebrowser/filebrowser:v2.63.3
    container_name: filebrowser
    user: "1000:1000"
    command: ["--noauth"]
    ports:
      - "8181:80"
    volumes:
      - {{ containers_setup_data_dir }}/filebrowser/config:/config
      - {{ containers_setup_data_dir }}/filebrowser/database:/database
      - /mnt/storage:/srv/storage
      - {{ containers_setup_data_dir }}:/srv/services-data
    labels:
      - homepage.group=Storage
      - homepage.name=Filebrowser
      - homepage.icon=filebrowser
      - homepage.href=http://homepage_host:8181
      - homepage.statusStyle=basic
      - homepage.ping=http://filebrowser:80
    healthcheck:
      # /healthcheck.sh is shipped in the image — wraps `wget --spider /health`
      # and reads port/address from /config/settings.json. Overriding only to
      # widen the image's default 5s interval (which spams logs every 5s).
      test: ["CMD", "/healthcheck.sh"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  ### Downloads ###
  # TRaSH-canonical single /data mount, identical to Radarr/Sonarr. Transmission
  # writes completed torrents into /data/torrents/{movies,tv} (the per-torrent
  # download-dir is set by Radarr/Sonarr when they add the torrent). Incomplete-
  # dir is disabled in settings.json — partial files get .part suffix in place.
  # Hardlinks from /data/torrents/* into /data/media/* are atomic because every
  # container sees them as a single mount.
  transmission:
    image: linuxserver/transmission:4.1.1
    container_name: transmission
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
      # LSIO clobbers settings.json's umask from this on every start. 002 →
      # group-writable files, required for Radarr/Sonarr (same PGID 1000) to
      # hardlink/delete Transmission's downloads.
      UMASK: "002"
      # Transmission 4.x still IP-filters even when rpc-whitelist-enabled is
      # false (undocumented anti-DNS-rebinding behaviour, log line "IP not
      # whitelisted"). Explicitly allow loopback + docker bridges + LAN here so
      # Radarr/Sonarr (sibling containers on the bridge) can reach the RPC.
      WHITELIST: "127.0.0.1,10.*.*.*,172.16.*.*,172.17.*.*,172.18.*.*,192.168.*.*"
      # Disable the Host-header rebinding check too — RPC is LAN/VPN-gated and
      # UFW blocks :9091 from the public internet, so this is acceptable.
      HOST_WHITELIST: "*"
    ports:
      - "9091:9091"
      - "51413:51413"
      - "51413:51413/udp"
    volumes:
      - {{ containers_setup_configs_dir }}/transmission-config:/config
      - /mnt/storage:/data
    labels:
      - homepage.group=Media
      - homepage.name=Transmission
      - homepage.icon=transmission
      - homepage.href=http://homepage_host:9091
      - homepage.statusStyle=basic
      - homepage.ping=http://transmission:9091
      - homepage.widget.type=transmission
      - homepage.widget.url=http://transmission:9091
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9091"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  ### Metrics ###
  glances:
    image: nicolargo/glances:4.3.1-full
    container_name: glances
    pid: host
    environment:
      TZ: {{ timezone }}
      # -w web/API mode; -t 10 = refresh every 10s instead of default 3s (homepage polls ~15s anyway);
      # disable plugins we never query (cuts per-tick work substantially on a Pi 5).
      GLANCES_OPT: "-w -t 10 --disable-plugin sensors,smart,raid,hddtemp,wifi,gpu,ports,irq,folders,amps"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /:/rootfs:ro
      - /etc/os-release:/etc/os-release:ro
    ports:
      - "61208:61208"
    labels:
      - homepage.group=Monitoring
      - homepage.name=Glances
      - homepage.icon=glances
      - homepage.href=http://homepage_host:61208
      - homepage.statusStyle=basic
      - homepage.ping=http://glances:61208
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:61208/api/4/status"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  netdata:
    image: netdata/netdata:v2.10
    container_name: netdata
    hostname: {{ device_name }}
    pid: host
    network_mode: host
    cap_add:
      - SYS_PTRACE
      - SYS_ADMIN
    security_opt:
      - apparmor:unconfined
    environment:
      - DISABLE_TELEMETRY=1
    volumes:
      - {{ containers_setup_configs_dir }}/netdata-config/netdata.conf:/etc/netdata/netdata.conf:ro
      - {{ containers_setup_configs_dir }}/netdata-config/stream.conf:/etc/netdata/stream.conf:ro
      - {{ containers_setup_configs_dir }}/netdata-config/go.d/pihole.conf:/etc/netdata/go.d/pihole.conf:ro
      - netdata-lib:/var/lib/netdata
      - netdata-cache:/var/cache/netdata
      - /:/host/root:ro,rslave
      - /etc/passwd:/host/etc/passwd:ro
      - /etc/group:/host/etc/group:ro
      - /etc/localtime:/etc/localtime:ro
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /etc/os-release:/host/etc/os-release:ro
      - /var/log:/host/var/log:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    labels:
      - homepage.group=Monitoring
      - homepage.name=Netdata
      - homepage.icon=netdata
      - homepage.href=http://homepage_host:19999/v3#
      - homepage.statusStyle=basic
      - homepage.ping=http://host.docker.internal:19999
      - homepage.widget.type=netdata
      - homepage.widget.url=http://host.docker.internal:19999
    restart: unless-stopped

  tailscale:
    image: tailscale/tailscale:v1.96
    container_name: tailscale
    hostname: pi5
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
    environment:
      TS_AUTHKEY: {{ tailscale_authkey }}
      TS_STATE_DIR: /var/lib/tailscale
      # Default is /tmp/tailscaled.sock symlinked into /var/run/tailscale — the
      # symlink target isn't shareable across containers, so put the real socket
      # in the shared volume directly. Traefik's `ts` resolver expects this path.
      TS_SOCKET: /var/run/tailscale/tailscaled.sock
      TS_EXTRA_ARGS: --accept-dns=false --advertise-exit-node
      TS_ENABLE_HEALTH_CHECK: true
    volumes:
      - {{ containers_setup_data_dir }}/tailscale:/var/lib/tailscale
      - /dev/net/tun:/dev/net/tun
      # Expose tailscaled.sock to traefik (which uses it for the `ts` cert resolver).
      - tailscale-socket:/var/run/tailscale
    labels:
      - homepage.group=Networking
      - homepage.name=Tailscale
      - homepage.icon=tailscale
    healthcheck:
      test: [ "CMD", "wget", "--spider", "-q", "http://127.0.0.1:9002/healthz" ]
    restart: unless-stopped
