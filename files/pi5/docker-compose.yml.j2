# {{ ansible_managed }}

networks:
  default:
    driver: bridge
    ipam:
      config:
        - subnet: {{ pi5_docker_network_subnet }}
          gateway: {{ pi5_docker_network_gateway }}

volumes:
  timemachine-var-lib-samba:
  timemachine-var-cache-samba:
  timemachine-run-samba:
  netdata-lib:
  netdata-cache:
  # Shared between the tailscale daemon and traefik so traefik's `ts` cert
  # resolver can talk to tailscaled.sock for the *.ts.net certificate.
  tailscale-socket:
  # Anki profile + AnkiConnect addon. A NAMED volume (not a bind mount) so Docker
  # seeds it from the image's baked /data on first run — the addon symlink and
  # webBindAddress=0.0.0.0 come from the image; a bind mount would shadow them
  # and AnkiConnect wouldn't bind/listen.
  anki-data:
  anki-export:

services:
  ### Utils ###
  myspeed:
    image: germannewsmaker/myspeed:1.0.9
    container_name: myspeed
    ports:
      - "5216:5216"
    volumes:
      - {{ containers_setup_data_dir }}/myspeed:/myspeed/data
    labels:
      - homepage.group=Monitoring
      - homepage.name=MySpeed
      - homepage.icon=myspeed
      - homepage.href=http://homepage_host:5216
      - homepage.statusStyle=basic
      - homepage.ping=http://myspeed:5216
      - homepage.widget.type=myspeed
      - homepage.widget.url=http://myspeed:5216
    restart: unless-stopped

  ### Reverse Proxy ###
  traefik:
    image: traefik:v3.7
    container_name: traefik
    hostname: traefik.pi5.{{ domain }}
    environment:
      # Used by the `cf` ACME resolver for DNS-01. Same token as cloudflare-ddns —
      # already has Zone:DNS:Edit on the chernyshev.work zone.
      CF_DNS_API_TOKEN: {{ cloudflare_api_token }}
    ports:
      - "80:80"
      - "443:443"
      - "8080:8080"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - {{ containers_setup_configs_dir }}/traefik-config.yml:/etc/traefik/traefik.yml:ro
      - {{ containers_setup_configs_dir }}/traefik-dynamic.yml:/etc/traefik/dynamic.yml:ro
      # /letsencrypt/acme.json is created with 0600 by the containers_setup role
      # ("Create ACME file with secure permissions"). Traefik refuses to use it otherwise.
      - {{ containers_setup_data_dir }}/traefik-letsencrypt:/letsencrypt
      - tailscale-socket:/var/run/tailscale
    labels:
      - "traefik.enable=true"
      # HTTPS router for the dashboard (cf wildcard cert).
      - "traefik.http.routers.traefik.rule=Host(`traefik.pi5.{{ domain }}`)"
      - "traefik.http.routers.traefik.service=api@internal"
      - "traefik.http.routers.traefik.entrypoints=websecure"
      - "traefik.http.routers.traefik.tls=true"
      - "traefik.http.routers.traefik.tls.certresolver=cf"
      # HTTP counterpart redirects to HTTPS.
      - "traefik.http.routers.traefik-http.rule=Host(`traefik.pi5.{{ domain }}`)"
      - "traefik.http.routers.traefik-http.entrypoints=web"
      - "traefik.http.routers.traefik-http.middlewares=https-redirect@file"
      - homepage.group=Networking
      - homepage.name=Traefik
      - homepage.icon=traefik
      - homepage.href=http://homepage_host:8080
      - homepage.statusStyle=basic
      - homepage.ping=http://traefik:8080
      - homepage.widget.type=traefik
      - homepage.widget.url=http://traefik:8080
    healthcheck:
      test: ["CMD", "traefik", "healthcheck", "--ping"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  ## Networking ##

  duckdns:
    image: linuxserver/duckdns:latest
    container_name: duckdns
    environment:
      TZ: {{ timezone }}
      SUBDOMAINS: {{ pi5_duckdns_subdomain }}
      TOKEN: {{ duckdns_token }}
      LOG_FILE: true
    labels:
      - homepage.group=Networking
      - homepage.name=DuckDNS
      - homepage.icon=duckdns
    restart: unless-stopped

  cloudflare-ddns:
    image: favonia/cloudflare-ddns:1.16.2
    container_name: cloudflare-ddns
    environment:
      CF_API_TOKEN: {{ cloudflare_api_token }}
      DOMAINS: "pi5.{{ domain }},*.pi5.{{ domain }}"
      PROXIED: "false"
      IP4_PROVIDER: cloudflare.trace
      IP6_PROVIDER: none
    labels:
      - homepage.group=Networking
      - homepage.name=Cloudflare DDNS
      - homepage.icon=cloudflare
    restart: unless-stopped

  wireguard:
    image: linuxserver/wireguard:1.0.20250521
    container_name: wireguard
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
      SERVERURL: {{ pi5_duckdns_subdomain }}.duckdns.org
      SERVERPORT: 51820
      INTERNAL_SUBNET: {{ vpn_network_subnet }}
    volumes:
      - {{ containers_setup_configs_dir }}/server-wg0.conf:/config/wg_confs/server_wg0.conf:ro
      - /lib/modules:/lib/modules
    ports:
      - "51820:51820/udp"
      # - "5000:5000"  # for wireguard-ui, set here as network_mode: service:wireguard
    sysctls:
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv4.ip_forward=1
    labels:
      - homepage.group=Networking
      - homepage.name=WireGuard
      - homepage.icon=wireguard
    healthcheck:
      test: ["CMD", "wg", "show", "server_wg0"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # TODO: thing about unbound to resolve DNS and not send it to the google etc
  pihole:
    image: pihole/pihole:2026.05.0
    container_name: pihole
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
      FTLCONF_webserver_api_password: ''  # no password
      FTLCONF_dns_listeningMode: 'ALL'
      FTLCONF_dns_upstreams: "1.1.1.1;8.8.8.8"
      DNSMASQ_LISTENING: "all"  # TODO: make local, but re-route from reserved-proxy
      FTLCONF_LOCAL_IPV4: "{{ local_ipv4 }}"
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "8053:80/tcp"  # custom port for web interface
    volumes:
      - {{ containers_setup_configs_dir }}/pihole/:/etc/pihole/:rw
      - {{ containers_setup_configs_dir }}/pihole-dnsmasq.d:/etc/dnsmasq.d/:rw
    labels:
      - "traefik.enable=true"
      # HTTPS router (cf wildcard cert).
      - "traefik.http.routers.pihole.rule=Host(`pihole.pi5.{{ domain }}`)"
      - "traefik.http.routers.pihole.entrypoints=websecure"
      - "traefik.http.routers.pihole.tls=true"
      - "traefik.http.routers.pihole.tls.certresolver=cf"
      - "traefik.http.routers.pihole.service=pihole"
      - "traefik.http.services.pihole.loadbalancer.server.port=80"
      # HTTP counterpart redirects to HTTPS.
      - "traefik.http.routers.pihole-http.rule=Host(`pihole.pi5.{{ domain }}`)"
      - "traefik.http.routers.pihole-http.entrypoints=web"
      - "traefik.http.routers.pihole-http.middlewares=https-redirect@file"
      - homepage.group=Services
      - homepage.name=Pi-hole
      - homepage.icon=pi-hole
      - homepage.href=http://homepage_host:8053/admin
      - homepage.statusStyle=basic
      - homepage.ping=http://pihole:80
      - homepage.widget.type=pihole
      - homepage.widget.url=http://pihole:80
      - homepage.widget.version=6
      - homepage.widget.key=
    networks:
      default:
        ipv4_address: {{ pi5_docker_network_pihole_ip }}
    healthcheck:
      test: ["CMD", "dig", "+norecurse", "+retry=0", "@127.0.0.1", "pi.hole"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  homepage:
    image: ghcr.io/gethomepage/homepage:v1.13.1
    container_name: homepage
    user: "1000:{{ docker_gid }}"
    environment:
      PUID: 1000
      PGID: 1000
      TZ: {{ timezone }}
      HOMEPAGE_ALLOWED_HOSTS: "*"
      LOG_PATH: /app/logs
    # Lets server-side widget calls reach host-network containers (netdata) via the bridge gateway.
    extra_hosts:
      - "host.docker.internal:host-gateway"
    ports:
      - "3000:3000"
    volumes:
      - {{ containers_setup_configs_dir }}/homepage-config:/app/config
      - {{ containers_setup_data_dir }}/homepage-logs:/app/logs
      - /var/run/docker.sock:/var/run/docker.sock:ro
    labels:
      - "traefik.enable=true"
      - "traefik.http.services.homepage.loadbalancer.server.port=3000"
      # HTTPS via the Cloudflare wildcard cert.
      - "traefik.http.routers.homepage.rule=Host(`pi5.{{ domain }}`)"
      - "traefik.http.routers.homepage.entrypoints=websecure"
      - "traefik.http.routers.homepage.tls=true"
      - "traefik.http.routers.homepage.tls.certresolver=cf"
      - "traefik.http.routers.homepage.service=homepage"
      # HTTP -> HTTPS for the canonical host.
      - "traefik.http.routers.homepage-http.rule=Host(`pi5.{{ domain }}`)"
      - "traefik.http.routers.homepage-http.entrypoints=web"
      - "traefik.http.routers.homepage-http.middlewares=https-redirect@file"
      # HTTPS via the Tailscale resolver for the MagicDNS hostname (no wildcards on .ts.net).
      - "traefik.http.routers.homepage-ts.rule=Host(`{{ device_name }}.gorgon-elver.ts.net`)"
      - "traefik.http.routers.homepage-ts.entrypoints=websecure"
      - "traefik.http.routers.homepage-ts.tls=true"
      - "traefik.http.routers.homepage-ts.tls.certresolver=ts"
      - "traefik.http.routers.homepage-ts.service=homepage"
      # Catch-all on :80 (low priority) so bare hostnames like http://pi5/ and
      # http://pi5.local/ still land on the dashboard without a cert warning.
      - "traefik.http.routers.homepage-fallback.rule=PathPrefix(`/`)"
      - "traefik.http.routers.homepage-fallback.priority=1"
      - "traefik.http.routers.homepage-fallback.entrypoints=web"
      - "traefik.http.routers.homepage-fallback.service=homepage"
    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://localhost:3000"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

{#  home-assistant:#}
