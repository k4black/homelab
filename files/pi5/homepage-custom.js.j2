// {{ ansible_managed }}
// Rewrite the "homepage_host" sentinel in every <a href> to whatever
// hostname the browser actually used to load homepage. Lets the same
// dashboard work over LAN IP, .local mDNS, Tailscale MagicDNS, and the
// public Cloudflare-managed domain without per-context links.
//
// Set service hrefs in docker labels (or services.yaml) as:
//   http://homepage_host:PORT/path
(() => {
  const SENTINEL = "homepage_host";
  const here = window.location.hostname;

  // Idempotent: only touches an anchor that still carries the sentinel, so
  // re-setting href never re-introduces it -> no observer feedback loop.
  const fix = (a) => {
    if (a.href && a.href.includes(SENTINEL)) a.href = a.href.replaceAll(SENTINEL, here);
  };
  const rewrite = (root) => {
    if (root.nodeType === 1 && root.matches && root.matches(`a[href*="${SENTINEL}"]`)) fix(root);
    if (root.querySelectorAll) root.querySelectorAll(`a[href*="${SENTINEL}"]`).forEach(fix);
  };

  rewrite(document);

  // Homepage is a React app: it both inserts tiles after initial paint AND
  // re-applies the original href (an *attribute* mutation) on later re-renders,
  // so watch childList (added nodes, incl. the anchor itself) and href attrs.
  new MutationObserver((mutations) => {
    for (const m of mutations) {
      if (m.type === "attributes" && m.target) fix(m.target);
      m.addedNodes.forEach((node) => {
        if (node.nodeType === 1) rewrite(node);
      });
    }
  }).observe(document.body, {
    childList: true,
    subtree: true,
    attributes: true,
    attributeFilter: ["href"],
  });
})();
